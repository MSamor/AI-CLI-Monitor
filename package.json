{
  "name": "ai-cli-monitor",
  "version": "0.1.0",
  "description": "AI CLI 状态监听桌面工具，支持灵动岛与 BLE 指示灯。",
  "author": {
    "name": "maosi",
    "email": "maosi@users.noreply.github.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/MSamor/AI-CLI-Monitor",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --publish never",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@abandonware/noble": "^1.9.2-25",
    "@electron-toolkit/preload": "^3.0.1",
    "framer-motion": "^12.42.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.15",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.4",
    "vite": "^5.3.5"
  },
  "engines": {
    "node": ">=18"
  },
  "build": {
    "appId": "com.maosi.ai-cli-monitor",
    "productName": "AI CLI Monitor",
    "copyright": "Copyright © 2026",
    "asar": true,
    "npmRebuild": false,
    "asarUnpack": [
      "**/*.node",
      "node_modules/@abandonware/noble/**",
      "node_modules/@abandonware/bluetooth-hci-socket/**",
      "node_modules/node-gyp-build/**"
    ],
    "extraResources": [
      {
        "from": "build/trayTemplate.png",
        "to": "trayTemplate.png"
      },
      {
        "from": "build/trayTemplate@2x.png",
        "to": "trayTemplate@2x.png"
      }
    ],
    "directories": {
      "output": "release"
    },
    "afterPack": "scripts/after-pack.cjs",
    "files": [
      "out/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!node_modules/.vite/**/*",
      "!node_modules/**/test{,s}/**/*",
      "!node_modules/**/*.map"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": true,
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${platform}-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${platform}-${arch}.${ext}"
    },
    "linux": {
      "category": "Development",
      "maintainer": "maosi <maosi@users.noreply.github.com>",
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "${productName}-${version}-${platform}-${arch}.${ext}"
    },
    "deb": {
      "maintainer": "maosi <maosi@users.noreply.github.com>"
    },
    "publish": null
  }
}
